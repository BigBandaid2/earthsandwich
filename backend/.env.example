# Copy this file to .env (project root) and fill in all required values before
# running docker compose up. Required variables must be present at startup;
# missing ones cause a clear error before any network calls are made.

# ── Database ─────────────────────────────────────────────────────────────────
# Connection string for PostgreSQL. In Docker Compose the host is the db service name.
DATABASE_URL=postgresql+asyncpg://earthsandwich:earthsandwich@db:5432/earthsandwich

# ── API Security ──────────────────────────────────────────────────────────────
# Bearer token for write endpoints (POST /trips, PUT /trips/:id, POST /regions/end-date).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=

# ── Instagram Ingestion ───────────────────────────────────────────────────────
# Personal Instagram account credentials used by instagrapi for session-based auth.
INSTA_USERNAME=
INSTA_PASSWORD=

# Path (inside the container) where the instagrapi session file is persisted.
INSTAGRAPI_SESSION_FILE=/app/instagrapi_session.json

# Optional: Instagram Graph API token for fallback if instagrapi fails (non-session error).
# Leave blank to disable the Graph API fallback entirely.
INSTAGRAM_GRAPH_API_TOKEN=

# How often to check for new Instagram posts (minutes). Default: 60
INSTAGRAM_POLL_INTERVAL_MINUTES=60

# ── AI — Location & IATA Inference ───────────────────────────────────────────
# Claude API key. Required for ALL location logic:
# - Determines IATA region code when Instagram provides a tagged location
# - Infers full location + IATA when no location tag is present
ANTHROPIC_API_KEY=

# ── Substack Ingestion ────────────────────────────────────────────────────────
# Full URL of the Substack RSS feed (e.g. https://example.substack.com/feed).
SUBSTACK_RSS_URL=

# How often to check for new Substack articles (minutes). Default: 60
SUBSTACK_POLL_INTERVAL_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────────────────
# Allowed origin for the frontend (used in CORS response headers).
FRONTEND_ORIGIN=http://localhost:5173

# ── Email Alerts (SMTP) ───────────────────────────────────────────────────────
# Used to send a notification when the instagrapi session expires or is challenged.
# If SMTP_HOST is blank, the email step is skipped and the error is logged only.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Logging & Environment ─────────────────────────────────────────────────────
# LOG_LEVEL: INFO | WARNING | ERROR | DEBUG. Default: INFO
LOG_LEVEL=INFO

# ENVIRONMENT: development (human-readable console logs) | production (JSON logs to stdout).
# Default: production
ENVIRONMENT=development
