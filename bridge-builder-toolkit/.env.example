# Copy to .env and fill in. .env is gitignored.

# Anthropic API key for the LLM-analyst layer (common/inference.py).
ANTHROPIC_API_KEY=

# Target database credentials are referenced BY ENV-VAR NAME in project.yml
# (FR-012 — credentials are never written into project.yml or passed on the CLI).
# Define whatever names your projects reference. Example: the 002 Travelogue Postgres.
TRAVELOGUE_DB_URL=
