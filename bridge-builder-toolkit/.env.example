# Copy to .env and fill in. .env is gitignored.

# Anthropic API key for the LLM-analyst layer (common/inference.py).
ANTHROPIC_API_KEY=

# Target database connections are defined PER PROJECT when you create one:
# `project create ... --target-cred-env <NAME>` names the environment variable
# that holds that project's DSN. The secret lives only in your environment (or
# in this file, gitignored); project.yml records the NAME, never the value
# (FR-012). Add one line per project, using whatever name you chose, e.g.:
#   <YOUR_PROJECT>_TARGET_DSN=postgresql://user:pass@host:5432/db
