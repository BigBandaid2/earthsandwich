# Copy this file to .env and fill in your values.
# Get these from Google Cloud Console → APIs & Services → Credentials
# and Maps Platform → Map IDs.

VITE_GOOGLE_MAPS_API_KEY=your_api_key_here

# Map ID is required for AdvancedMarker (create one under Maps Platform → Map IDs,
# choose "JavaScript" map type; no cloud styling required).
VITE_GOOGLE_MAPS_MAP_ID=your_map_id_here

# Backend API base URL (no trailing slash).
# Local dev: http://localhost:8000
# Docker Compose: http://backend:8000 (override in docker-compose.yml via environment)
VITE_API_BASE_URL=http://localhost:8000
