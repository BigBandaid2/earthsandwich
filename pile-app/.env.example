# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit credentials.

# --- Instagram crawler account (FR-016, FR-055) ---
# Use a burner account distinct from the targets you scrape.
INSTA_USERNAME=
INSTA_PASSWORD=

# --- LLM provider (FR-019, FR-020) ---
# Get a key at https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Optional override for the working model. Defaults to claude-sonnet-4-6.
# ANTHROPIC_MODEL=claude-sonnet-4-6
